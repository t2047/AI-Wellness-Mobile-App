# =============================================================================
# Wellness Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Backend API ---
# URL of the Java Spring Boot backend
BACKEND_URL=http://localhost:8080
# JWT token used by the agent to authenticate with the backend
AGENT_JWT_TOKEN=

# --- RAG chat model (OpenAI-compatible endpoint for final RAG answers) ---
RAG_CHAT_PROVIDER=qwen
RAG_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_CHAT_API_KEY=
RAG_CHAT_MODEL=qwen3.7-plus

# --- DeepSeek legacy fallback (used only when RAG_CHAT_* is not set) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Doubao (embedding model for RAG) ---
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
DOUBAO_EMBED_MODEL=doubao-embedding-vision-251215

# --- OpenAI-compatible GPT fallback for non-RAG direct chat ---
# ZHAO LEI: alternatively set DASHSCOPE_API_KEY for Alibaba Cloud Model Studio.
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
OPENAI_CHAT_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
OPENAI_MODEL=qwen3.7-plus

# --- RAG Index ---
# Glob pattern for MSD corpus chunk files (*.jsonl)
RAG_CORPUS_GLOB=
# Path to store the built RAG index
RAG_STORE_PATH=
# Number of top chunks to retrieve per query
RAG_TOP_K=5
# Max characters per retrieval chunk
RAG_CHUNK_MAX_CHARS=1200
# Max tokens for the generated answer
RAG_ANSWER_MAX_TOKENS=900
# Temperature for answer generation (0.0-1.0)
RAG_ANSWER_TEMPERATURE=0.2
