# =============================================================================
# Wellness Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Backend API ---
# URL of the Java Spring Boot backend
BACKEND_URL=http://localhost:8080
# JWT token used by the agent to authenticate with the backend
AGENT_JWT_TOKEN=

# --- DeepSeek (LLM for RAG answers & agent reasoning) ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Doubao (Embedding model for RAG) ---
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_EMBED_MODEL=doubao-embedding-vision-251215

# --- RAG Index ---
# Glob pattern for MSD corpus chunk files (*.jsonl)
RAG_CORPUS_GLOB=
# Path to store the built RAG index
RAG_STORE_PATH=
# Number of top chunks to retrieve per query
RAG_TOP_K=5
# Max characters per retrieval chunk
RAG_CHUNK_MAX_CHARS=1200
# Max tokens for the generated answer
RAG_ANSWER_MAX_TOKENS=900
# Temperature for answer generation (0.0-1.0)
RAG_ANSWER_TEMPERATURE=0.2
