# =============================================================================
# Wellness Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Backend API ---
# URL of the Java Spring Boot backend
BACKEND_URL=http://localhost:8080
# JWT token used by the agent to authenticate with the backend
AGENT_JWT_TOKEN=

# --- DeepSeek (Default LLM for RAG answers & agent reasoning) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Doubao (embedding model for RAG) ---
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
DOUBAO_EMBED_MODEL=doubao-embedding-vision-251215

# --- RAG Index ---
RAG_CORPUS_GLOB=./scraper/output/*_msd_chunks.jsonl
RAG_STORE_PATH=../agent/rag_store/rag_index.json
RAG_TOP_K=5
RAG_CHUNK_MAX_CHARS=1200
RAG_ANSWER_MAX_TOKENS=900
RAG_ANSWER_TEMPERATURE=0.2
