# Copy this file to .env and fill in local secrets.
# Do not commit .env or any real API keys.

# JWT_SECRET=replace-with-at-least-32-random-characters
AGENT_BASE_URL=http://localhost:5001
BACKEND_URL=http://localhost:8080

# --- RAG (retrieval-augmented generation) ---
RAG_CORPUS_GLOB=../scraper/output/*_msd_chunks.jsonl
RAG_TOP_K=5
RAG_CHUNK_MAX_CHARS=1200
RAG_ANSWER_MAX_TOKENS=900
RAG_ANSWER_TEMPERATURE=0.2

# --- RAG chat model (OpenAI-compatible endpoint for final RAG answers) ---
RAG_CHAT_PROVIDER=qwen
RAG_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_CHAT_API_KEY=
RAG_CHAT_MODEL=qwen3.7-plus

# --- DeepSeek legacy fallback (used only when RAG_CHAT_* is not set) ---
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# --- Doubao (embedding model for RAG) ---
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
DOUBAO_EMBED_MODEL=doubao-embedding-vision-251215

# Optional: DashScope / OpenAI-compatible fallback for non-RAG direct chat.
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
OPENAI_CHAT_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
OPENAI_MODEL=qwen3.7-plus

# Optional backend/database overrides.
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_URL=jdbc:mysql://localhost:3306/wellness_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
