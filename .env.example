# Copy this file to .env and fill in local secrets.
# Do not commit .env or any real API keys.

# Direct backend chatbot fallback.
# ZHAO LEI: DashScope and other OpenAI-compatible endpoints are supported.
AI_PROVIDER=openai
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
OPENAI_CHAT_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
OPENAI_MODEL=qwen3.7-plus

# Optional: original DeepSeek direct provider.
# Set AI_PROVIDER=deepseek to use these from the Spring backend.
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Optional: original Python RAG embedding provider.
# Without Doubao, the Python agent keeps /chat and /rag/ask working through GPT fallback,
# while /rag/reindex remains unavailable.
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_EMBED_MODEL=doubao-embedding-text-240715

# Optional backend/database overrides.
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_URL=jdbc:mysql://localhost:3306/wellness_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
# JWT_SECRET=replace-with-at-least-32-random-characters
AGENT_BASE_URL=http://localhost:5001
BACKEND_URL=http://localhost:8080
