<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WellnessApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primaryDark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.WellnessApp.PlainLogin" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/welleaf_splash_background</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
